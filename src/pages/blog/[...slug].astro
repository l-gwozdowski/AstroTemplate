---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

type BlogEntry = CollectionEntry<'blog'>;

interface Props {
  post: BlogEntry;
  previousPost: BlogEntry | null;
  nextPost: BlogEntry | null;
}

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      previousPost: posts[index - 1] ?? null,
      nextPost: posts[index + 1] ?? null,
    },
  }));
}

const { post, previousPost, nextPost } = Astro.props as Props;
const { Content } = await render(post);
---

<BlogPost {...post.data} previousPost={previousPost} nextPost={nextPost}>
  <Content />
</BlogPost>
