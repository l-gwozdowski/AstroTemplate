---
import { SITE } from '../../../config/site';
---

<section id="home" aria-labelledby="hero-title" class="hero-panel">
  <p class="eyebrow">One-page starter</p>
  <h1 id="hero-title">{SITE.title}</h1>
  <p class="lead">{SITE.description}</p>
  <p class="tagline">{SITE.tagline}</p>
  <div class="hero-actions">
    <a class="button-primary" href="/#contact">Start conversation</a>
    <a class="button-ghost" href="/blog">Open blog</a>
  </div>
</section>
