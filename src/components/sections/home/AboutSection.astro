---
import { AUTHOR } from '../../../config/site';
---

<section id="about" aria-labelledby="about-title" class="about-card">
  <p class="eyebrow">About</p>
  <h2 id="about-title">Built as a one-pager with reusable sections</h2>
  <p>
    Keep this section for positioning, trust, and short brand story. You can swap this copy for team
    intro, market focus, or proof points.
  </p>
  <p>
    Maintained by {AUTHOR.name} ({AUTHOR.role}). Contact
    <a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a>.
  </p>
</section>
